{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lunery Lab Studio",
  "version": "0.1.0",
  "identifier": "com.lunerylab.studio",
  "build": {
    "beforeDevCommand": "pnpm desktop:runtime:dev",
    "devUrl": "http://127.0.0.1:3000/studio",
    "beforeBuildCommand": "pnpm desktop:clean && pnpm build && pnpm desktop:prepare",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Lunery Lab Studio",
        "width": 1440,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: blob: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "GraphicsAndDesign",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../desktop-server",
      "../engine",
      "../engine/licenses",
      "../../THIRD_PARTY_NOTICES.md"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
