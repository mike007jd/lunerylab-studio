NEXT_PUBLIC_SITE_URL="https://www.lunerylab.com"

# === Database ===
DATABASE_URL=""

# === Vercel Blob (persistent private asset storage in production) ===
# Production on Vercel should use blob storage. Local/desktop media defaults to
# the visible Lunery profile; set ECOM_STORAGE_DIR only to an absolute override.
BLOB_READ_WRITE_TOKEN=""
ECOM_STORAGE_DRIVER="auto"

# === App Config ===
# Desktop / local-dev escape hatch ONLY. Set to "1" to expose the workspace
# data API (projects, library, canvas) over the web server. MUST stay empty /
# unset on the Vercel marketing deployment — setting it bypasses the production
# gate that returns 403 for every workspace route. The desktop app never needs
# it (it runs with LUNERY_DESKTOP=1).
ECOM_ENABLE_WEB_WORKSPACE_API=""
ECOM_STORAGE_DIR=""
ECOM_MAX_UPLOAD_BYTES_PER_FILE="10485760"
ECOM_MAX_STORAGE_BYTES_PER_USER="1073741824"
