{
  "name": "lunerylab-studio",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.23.1",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "desktop:build": "node scripts/desktop-build.mjs",
    "desktop:build:local": "node scripts/desktop-build-local.mjs",
    "desktop:check": "node scripts/desktop-check.mjs",
    "desktop:clean": "node scripts/desktop-clean.mjs",
    "desktop:dev": "node scripts/desktop-tauri-dev.mjs",
    "desktop:prepare": "node scripts/fetch-llama-server.mjs && node scripts/fetch-sd-server.mjs && node scripts/fetch-mlx-server.mjs && node scripts/desktop-bundle-assets.mjs && node scripts/desktop-sign-sidecars.mjs",
    "engine:fetch": "node scripts/fetch-llama-server.mjs",
    "engine:fetch:sd": "node scripts/fetch-sd-server.mjs",
    "engine:fetch:mlx": "node scripts/fetch-mlx-server.mjs",
    "desktop:runtime:dev": "node scripts/desktop-next-dev.mjs",
    "desktop:info": "tauri info",
    "ai:freshness": "node scripts/audit-ai-freshness.mjs",
    "build": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "lint": "eslint",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "ui:check": "node scripts/check-ui-framework.mjs",
    "licenses:check": "node scripts/verify-third-party-licenses.mjs",
    "prisma:generate": "prisma generate",
    "verify": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm ui:check && pnpm licenses:check && pnpm ai:freshness"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.81",
    "@ai-sdk/google": "3.0.80",
    "@ai-sdk/openai": "3.0.67",
    "@ai-sdk/openai-compatible": "2.0.48",
    "@ai-sdk/provider-utils": "4.0.30",
    "@ai-sdk/react": "3.0.210",
    "@assistant-ui/react": "^0.14.23",
    "@assistant-ui/react-ai-sdk": "1.3.37",
    "@assistant-ui/react-markdown": "^0.14.4",
    "@electric-sql/pglite": "0.5.3",
    "@electric-sql/pglite-socket": "0.2.4",
    "@fal-ai/client": "1.10.1",
    "@prisma/client": "^6.17.1",
    "@tauri-apps/api": "2.11.0",
    "@vercel/functions": "^3.6.1",
    "ai": "^6.0.208",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "konva": "10.3.0",
    "lucide-react": "^0.575.0",
    "mime-types": "^3.0.2",
    "next": "16.2.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-konva": "19.2.5",
    "remark-gfm": "^4.0.1",
    "replicate": "1.4.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-shimmer": "^0.4.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "happy-dom": "^20.10.6",
    "prisma": "^6.17.1",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "4.1.8"
  }
}
